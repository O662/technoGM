<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TODAY"
        android:textColor="#00F5FF"
        android:textSize="9sp"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        android:layout_marginBottom="4dp" />

    <!-- Two-column stat grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Left column: Steps + Water -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="8dp">

            <!-- Steps -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STEPS"
                    android:textColor="#8890B5"
                    android:textSize="7sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/steps_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/steps_progress"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:progressTint="#00F5FF"
                    android:progressBackgroundTint="#1A1A2E"
                    android:indeterminate="false"
                    android:max="10000"
                    android:progress="0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="/ 10,000"
                    android:textColor="#444466"
                    android:textSize="7sp" />
            </LinearLayout>

            <!-- Water -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WATER"
                    android:textColor="#8890B5"
                    android:textSize="7sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/water_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- mL"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/water_progress"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:progressTint="#7B2FFF"
                    android:progressBackgroundTint="#1A1A2E"
                    android:indeterminate="false"
                    android:max="2000"
                    android:progress="0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="/ 2,000 mL"
                    android:textColor="#444466"
                    android:textSize="7sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Right column: Active + Calories + Streak -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Active Minutes -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACTIVE"
                    android:textColor="#8890B5"
                    android:textSize="7sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/active_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- MIN"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/active_progress"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:progressTint="#00FF88"
                    android:progressBackgroundTint="#1A1A2E"
                    android:indeterminate="false"
                    android:max="30"
                    android:progress="0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="/ 30 MIN"
                    android:textColor="#444466"
                    android:textSize="7sp" />
            </LinearLayout>

            <!-- Calories -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CALORIES"
                    android:textColor="#8890B5"
                    android:textSize="7sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/calories_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- KCAL"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/calories_progress"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:progressTint="#FFE600"
                    android:progressBackgroundTint="#1A1A2E"
                    android:indeterminate="false"
                    android:max="500"
                    android:progress="0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="/ 500 KCAL"
                    android:textColor="#444466"
                    android:textSize="7sp" />
            </LinearLayout>

            <!-- Streak -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STREAK  "
                    android:textColor="#8890B5"
                    android:textSize="7sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/streak_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- WKS"
                    android:textColor="#FF6B00"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
